---

<section
  class="bg-black h-screen min-h-screen text-center relative overflow-hidden"
>
  <div class="z-30 relative flex flex-col h-full">
    <div>
      <h2 class="text-white pt-40 text-[40px] font-medium">
        Disfrute de Tesla
      </h2>
      <p class="text-white text-sm">
        Programe una prueba de conducción hoy mismo
      </p>
    </div>

    <div class="flex flex-col grow justify-end pb-20">
      <div>
        <a
          href="#"
          class="border-[2px] border-white bg-white/5 backdrop-blur-sm text-sm rounded font-medium text-white px-12 py-2 inline-block hover:bg-white hover:text-black transition-colors duration-500"
          >Prueba de conducción</a
        >
      </div>
    </div>
  </div>

  <div class="absolute top-0 bottom-0 h-full w-full z-10">
    <video
      autoplay
      muted
      loop
      src="/video.webm"
      class="object-cover object-center h-full w-full"></video>
  </div>
</section>
